#!/bin/sh
set -e

case "${1:-}" in
	remove | purge)
		# prerm performs all managed-path cleanup while holding Steward's lifecycle
		# lock. Do not mutate those paths after that lock is released: activation
		# may legitimately have repaired them while package removal completed.
		systemctl daemon-reload >/dev/null 2>&1 || true
		;;
esac

if [ "${1:-}" = purge ] && [ -d /etc/steward ]; then
	echo "steward-node: preserving /etc/steward because package purge does not retire durable node identity" >&2
	echo "  Use the versioned uninstall-node helper with --purge-config --purge-data for an explicit guarded retirement." >&2
fi

exit 0
