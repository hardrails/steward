+/// Verify every complete event returned by the relay before any field is used
+/// or normalized. Relay-side verification is not a client trust boundary: a
+/// compromised or misconfigured relay must not be able to fabricate an author,
+/// tag, event ID, or message body for an automation consumer.
+fn verify_query_events(events: &[serde_json::Value]) -> Result<(), CliError> {
+    for raw in events {
+        let event: nostr::Event = serde_json::from_value(raw.clone())
+            .map_err(|_| CliError::Other("query returned a malformed Nostr event".into()))?;
+        event.verify().map_err(|_| {
+            CliError::Other("query returned an event with an invalid id or signature".into())
+        })?;
+    }
+    Ok(())
+}
