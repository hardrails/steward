# Replace the example URL and install the credential, token, and CA files before
# running scripts/node-preflight.sh. Values must not contain whitespace.
EXECUTOR_TOKEN_FILE=/etc/steward/executor-token
EXECUTOR_DOCKER_SOCKET=/var/run/docker.sock
EXECUTOR_UPLINK_URL=
EXECUTOR_UPLINK_CREDENTIAL_FILE=
EXECUTOR_UPLINK_STATE_FILE=
EXECUTOR_UPLINK_TLS_CA_FILE=
EXECUTOR_MAX_MEMORY_BYTES=536870912
EXECUTOR_MAX_CPU_MILLIS=1000
EXECUTOR_MAX_PIDS=128
EXECUTOR_MAX_WORKLOADS=32
EXECUTOR_MAX_WORKLOADS_PER_TENANT=4
