{
  "addr": "127.0.0.1:8080",
  "disable_inbound_listener": true,
  "enable_process_exec": false,
  "log_level": "info",
  "max_instances": 1024,
  "state_file": "/var/lib/steward/state.json",
  "uplink_command_queue_depth": 256,
  "uplink_credential_file": "/etc/steward/uplink-credential.json",
  "uplink_poll_interval": "10s",
  "uplink_tls_ca_file": "/etc/steward/railyard-ca.pem",
  "uplink_tls_skip_verify": false,
  "uplink_url": "https://railyard.example.invalid"
}
