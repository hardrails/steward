#!/bin/sh
set -e

case "${1:-}" in
	remove | purge)
		for binary in steward stewardctl steward-mcp steward-executor steward-gateway steward-relay; do
			path="/usr/local/bin/$binary"
			target=$(readlink "$path" 2>/dev/null || true)
			case "$target" in
				/opt/steward/current/* | /opt/steward/releases/*) rm -f "$path" ;;
			esac
		done
		rm -rf /usr/local/libexec/steward
		rm -f /usr/local/lib/systemd/system/steward.service \
			/usr/local/lib/systemd/system/steward-executor.service \
			/usr/local/lib/systemd/system/steward-gateway.service
		systemctl daemon-reload >/dev/null 2>&1 || true
		;;
esac

if [ "${1:-}" = purge ] && [ -d /etc/steward ]; then
	echo "steward-node: preserving /etc/steward because package purge does not retire durable node identity" >&2
	echo "  Use the versioned uninstall-node helper with --purge-config --purge-data for an explicit guarded retirement." >&2
fi

exit 0
