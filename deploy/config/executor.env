# Replace the example URL and install the credential, token, and CA files before
# running scripts/node-preflight.sh. Values must not contain whitespace.
EXECUTOR_TOKEN_FILE=/etc/steward/executor-token
EXECUTOR_OPERATOR_TOKEN_FILE=/etc/steward/executor-operator-token
EXECUTOR_OBSERVER_TOKEN_FILE=/etc/steward/executor-observer-token
EXECUTOR_DOCKER_SOCKET=/var/run/docker.sock
EXECUTOR_UPLINK_URL=
EXECUTOR_UPLINK_CREDENTIAL_FILE=
EXECUTOR_UPLINK_STATE_FILE=
EXECUTOR_UPLINK_DELIVERY_STATE_FILE=
EXECUTOR_UPLINK_PROTOCOL_VERSION=0
EXECUTOR_UPLINK_TLS_CA_FILE=
EXECUTOR_EVIDENCE_UPLINK_ENABLED=false
EXECUTOR_EVIDENCE_UPLINK_CONTROLLER_INSTANCE_ID=
EXECUTOR_EVIDENCE_UPLINK_POLL_INTERVAL=30s
EXECUTOR_MAX_MEMORY_BYTES=536870912
EXECUTOR_MAX_CPU_MILLIS=1000
EXECUTOR_MAX_PIDS=128
EXECUTOR_MAX_WORKLOADS=32
EXECUTOR_MAX_WORKLOADS_PER_TENANT=4
EXECUTOR_MAX_TOTAL_MEMORY_BYTES=8589934592
EXECUTOR_MAX_TOTAL_CPU_MILLIS=8000
EXECUTOR_MAX_TOTAL_PIDS=2048
EXECUTOR_MAX_TENANT_MEMORY_BYTES=2147483648
EXECUTOR_MAX_TENANT_CPU_MILLIS=2000
EXECUTOR_MAX_TENANT_PIDS=512
EXECUTOR_NODE_LABELS=
EXECUTOR_NODE_TAINTS=
EXECUTOR_STATE_ARG=
EXECUTOR_ADMISSION_HOST_ADMIN_ARG=
